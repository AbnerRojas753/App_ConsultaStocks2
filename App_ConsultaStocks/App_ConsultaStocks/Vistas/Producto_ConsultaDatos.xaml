<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_ConsultaStocks.Vistas.Producto_ConsultaDatos"
             Shell.TabBarIsVisible="False"
             >
    
    <ContentPage.Content >

        <StackLayout Spacing="0" Margin="0,0,0,0" >

            <Label Text="Stocks de Productos"
                   Margin="0,0,0,10"
                   FontSize="18"   
                   HorizontalOptions="Center"
                   TextColor="Red"
                   />
                     
                   
            <StackLayout Orientation="Horizontal" Margin="0,10,0,0"> 
                <Label  Text="Producto: "
                        TextColor="IndianRed"
                        VerticalOptions="CenterAndExpand"
                        />
                
                <Frame  Padding="0" CornerRadius="15" HorizontalOptions="Start">
                    <Entry Keyboard="Numeric"
                           Placeholder="||| Leer código de barras  |||"
                           x:Name="txtcodigobarras" 
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="CenterAndExpand"
                           FontSize="15"
                           Completed="txtcodigobarras_Completed"
                           />
                </Frame>
                
                <Button Text=""
                        ImageSource="BarCodeMini.png"
                        BackgroundColor="WhiteSmoke"
                        CornerRadius="10"
                        FontSize="15"
                        x:Name="btnLeerCodBar"
                        Clicked="btnLeerCodBar_Clicked" 
                        HorizontalOptions="StartAndExpand"

                        />
                                           
            </StackLayout>
                      
                    <Label Text="Descripción:"
                            FontSize="18"
                           />

                    
                    <Label TextColor="Black"
                           Text=""
                           FontSize="18"
                           FontAttributes="None" 
                           x:Name="lblDescripcionProducto"
                           />
                    
                    <StackLayout Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Text="SKU:"
                               FontSize="18"   
                               VerticalOptions="CenterAndExpand"
                               />
                        
                        <Label TextColor="Black"
                            Text="               "
                           FontSize="18"
                           FontAttributes="None" 
                           x:Name="Lbl_Codigo"
                           />


                        <Label Text="   Stock Total: "
                               FontSize="18"
                               VerticalOptions="CenterAndExpand"
                    
                                />
                        
                        <Label TextColor="Black"
                               Text=""
                               FontSize="18"    
                               x:Name="Lbl_StockTotal"
                               />
                        
                        
                        
                    </StackLayout>
                    
                    <Grid Padding="0" ColumnSpacing="0" x:Name="GridStocks" BackgroundColor="WhiteSmoke">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.45*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="0.5*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Label Text="IdAlm" Grid.Column="0" Grid.Row="0" TextColor="Black"/>
                        <Label Text="Nombre" Grid.Column="1" Grid.Row="0"  TextColor="Black"/>
                        <Label Text="Conta" Grid.Column="2" Grid.Row="0" HorizontalOptions="End" TextColor="Black"/>
                        <Label Text="Reser" Grid.Column="3" Grid.Row="0" HorizontalOptions="End" TextColor="Black"/>
                        <Label Text="Dispo" Grid.Column="4" Grid.Row="0" HorizontalOptions="End" TextColor="Black"/>
                        
                    </Grid>

                    <ListView   Margin="0,0,0,0"
                                    x:Name="LV_ListaStocks"
                                    BackgroundColor="Transparent"
                                  
                                >
                                        
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ViewCell>
                                    <Grid Padding="4" ColumnSpacing="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.45*"/>
                                            <ColumnDefinition Width="1.8*"/>
                                            <ColumnDefinition Width="0.5*"/>
                                            <ColumnDefinition Width="0.5*"/>
                                            <ColumnDefinition Width="0.5*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Label Text="{Binding CodAlmacén}"          Grid.Column="0" Grid.Row="0" HorizontalOptions="Start" />
                                        <Label Text="{Binding Almacén}"             Grid.Column="1" Grid.Row="0" HorizontalOptions="Start" />
                                        <Label Text="{Binding Contabilizado}"    Grid.Column="2" Grid.Row="0" HorizontalOptions="End" />
                                        <Label Text="{Binding Reservado}"    Grid.Column="3" Grid.Row="0" HorizontalOptions="End" />
                                        <Label Text="{Binding Stock_Disponible}"    Grid.Column="4" Grid.Row="0" HorizontalOptions="End" />

                                    </Grid>
                                </ViewCell>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>  
                </StackLayout>
           
    </ContentPage.Content>
</ContentPage>