            <StackLayout Orientation="Horizontal" Margin="0,0,0,10">

                <Button Text="Guardar datos"  x:Name="Btn_GuardarDatos" Clicked="Btn_GuardarDatos_Clicked" HorizontalOptions="CenterAndExpand">
                    
                </Button>

                <Button Text="Eliminar"  x:Name="Btn_EliminarDatos" Clicked="Btn_EliminarDatos_Clicked" HorizontalOptions="CenterAndExpand">

                </Button>

                <Button Text="Limpiar" x:Name="Btn_Limpiar" Clicked="Btn_Limpiar_Clicked" HorizontalOptions="CenterAndExpand">

                </Button>
                

            </StackLayout>-->
        </StackLayout>




    </ContentPage.Content>
</ContentPage>