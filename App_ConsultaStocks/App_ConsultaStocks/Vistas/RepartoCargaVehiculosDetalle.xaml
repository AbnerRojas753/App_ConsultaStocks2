<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_ConsultaStocks.Vistas.RepartoCargaVehiculosDetalle">
    <ContentPage.Content>
        <StackLayout>

            <StackLayout Margin="0,10,0,0">
                <Label Text="Detalle de Carga - Despachos"
                       FontSize="18"
                       HorizontalOptions="Center"
                       TextColor="Red" />
            </StackLayout>

            <Frame Padding="8" CornerRadius="15" Margin="0,10,0,0" BorderColor="Gainsboro">
                <StackLayout>
                    <StackLayout Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Text="Cliente:" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="lblCliente" Text="" FontSize="14" VerticalOptions="Center" HorizontalOptions="FillAndExpand" LineBreakMode="WordWrap" />
                    </StackLayout>

                    <StackLayout Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Text="Dirección:" FontSize="12" VerticalOptions="Center" />
                        <Label x:Name="lblDireccion" Text="" FontSize="12" VerticalOptions="Center" TextColor="Gray" />
                    </StackLayout>

                    <StackLayout Orientation="Horizontal" Margin="0,10,0,0">
                        <Label Text="Total Despachos:" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="lblTotalDespachos" Text="0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" TextColor="DarkBlue" />
                    </StackLayout>

                    <StackLayout Orientation="Horizontal" Margin="0,5,0,0">
                        <Label Text="Total Bultos:" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="lblTotalBultos" Text="0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" TextColor="Green" />
                        <Label Text="  |  Cargados:" FontSize="12" VerticalOptions="Center" />
                        <Label x:Name="lblBultosCargados" Text="0" FontSize="12" VerticalOptions="Center" TextColor="Blue" />
                        <Label Text="  |  Pendientes:" FontSize="12" VerticalOptions="Center" />
                        <Label x:Name="lblBultosPendientes" Text="0" FontSize="12" VerticalOptions="Center" TextColor="Red" />
                    </StackLayout>
                </StackLayout>
            </Frame>

            <Frame Padding="8" CornerRadius="15" Margin="0,10,0,0" BorderColor="LightGreen">
                <StackLayout>
                    <Button Text="INICIAR CARGA" 
                            x:Name="btnIniciar" 
                            Clicked="btnIniciar_Clicked" 
                            BackgroundColor="LightBlue" 
                            CornerRadius="10" 
                            Margin="0,5,0,5"
                            IsVisible="False" />

                    <StackLayout x:Name="panelEscaneo" IsVisible="False">
                        <Label Text="Escanear bulto para cargar" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center" 
                               TextColor="Red" />

                        <StackLayout Orientation="Horizontal" Margin="0,10,0,0">
                            <Frame Padding="0" HorizontalOptions="FillAndExpand" x:Name="frameBulto">
                                <Entry x:Name="entryBulto"
                                       Placeholder="|||..Escanear Bulto..|||"
                                       HorizontalTextAlignment="Center"
                                       Completed="entryBulto_Completed" />
                            </Frame>
                            <Button Text=""
                                    ImageSource="BarCodeMini2.png"
                                    BackgroundColor="WhiteSmoke"
                                    CornerRadius="10"
                                    x:Name="btnScannerBulto"
                                    HorizontalOptions="End"
                                    Clicked="btnScannerBulto_Clicked" />
                        </StackLayout>
                    </StackLayout>

                    <Button Text="FINALIZAR CARGA" 
                            x:Name="btnFinalizar" 
                            Clicked="btnFinalizar_Clicked" 
                            BackgroundColor="LightGreen" 
                            CornerRadius="10" 
                            Margin="0,15,0,0"
                            IsVisible="False" />
                </StackLayout>
            </Frame>

            <Frame Padding="8" CornerRadius="15" Margin="0,10,0,0" BorderColor="LightPink">
                <StackLayout>
                    <Label Text="Lista de Bultos" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />

                    <ListView x:Name="listViewBultos" 
                              HasUnevenRows="True" 
                              BackgroundColor="Transparent" 
                              SeparatorVisibility="Default" 
                              SeparatorColor="#444444">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ViewCell>
                                    <Grid Padding="5" ColumnSpacing="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.60*"/>
                                            <ColumnDefinition Width="0.40*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Text="{Binding Descripcion}" 
                                               Grid.Column="0" 
                                               FontSize="Small" 
                                               VerticalOptions="Center" />
                                        
                                        <Label Text="{Binding Estado}" 
                                               Grid.Column="1" 
                                               FontSize="Small" 
                                               FontAttributes="Bold"
                                               TextColor="{Binding EstadoColor}"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </ViewCell>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackLayout>
            </Frame>

        </StackLayout>
    </ContentPage.Content>
</ContentPage>